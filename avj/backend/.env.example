# ─── Copy to .env and fill in real values ─────────────────────
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-this-to-a-random-secret-key

# Overridden by docker-compose in production (points to postgres service).
# For local dev set to your local postgres URL.
DATABASE_URL=postgresql+asyncpg://avj:PASSWORD@localhost:5432/avj

# ─── Spotify ──────────────────────────────────────────────────
# 1. https://developer.spotify.com/dashboard → create app
# 2. Add Redirect URI: https://avj.dilyor.dev/api/connect/spotify/callback
# 3. Copy Client ID + Secret below

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://avj.dilyor.dev/api/connect/spotify/callback

# ─── Yandex Music ─────────────────────────────────────────────
# Optional — users provide their own token via the UI.
YANDEX_CLIENT_ID=

# ─── Other ────────────────────────────────────────────────────
POLL_INTERVAL=30
CORS_ORIGINS=https://avj.dilyor.dev
FRONTEND_URL=https://avj.dilyor.dev
